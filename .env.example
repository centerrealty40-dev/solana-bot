# ------------------------------------------------------------
# W7.4 — Pre-entry price verification (Jupiter quote sanity check)
# Rollback: PAPER_PRICE_VERIFY_ENABLED=0 (no quote calls, no jsonl stamping).
# Shadow: ENABLED=1, BLOCK_ON_FAIL=0 (verdict stamped; opens still proceed).
# Optional: USE_JUPITER_PRICE=1 sets effective entry to Jupiter-implied price.
# ------------------------------------------------------------
PAPER_PRICE_VERIFY_ENABLED=0
PAPER_PRICE_VERIFY_BLOCK_ON_FAIL=0
PAPER_PRICE_VERIFY_USE_JUPITER_PRICE=0
PAPER_PRICE_VERIFY_MAX_SLIP_PCT=4.0
PAPER_PRICE_VERIFY_MAX_SLIP_BPS=400
PAPER_PRICE_VERIFY_MAX_PRICE_IMPACT_PCT=8.0
PAPER_PRICE_VERIFY_TIMEOUT_MS=2500
# W7.4.1 — Jupiter quote retries + circuit (shared: W7.4 entry, W7.4.2 exit, W7.6 impulse, W7.8 quote fetch).
# Rollback: PAPER_PRICE_VERIFY_QUOTE_RETRIES_ENABLED=0 PAPER_PRICE_VERIFY_CIRCUIT_ENABLED=0
PAPER_PRICE_VERIFY_QUOTE_RETRIES_ENABLED=1
PAPER_PRICE_VERIFY_QUOTE_MAX_ATTEMPTS=3
PAPER_PRICE_VERIFY_QUOTE_RETRY_BACKOFF_MS=300
PAPER_PRICE_VERIFY_CIRCUIT_ENABLED=1
