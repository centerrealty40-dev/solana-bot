# ============================================================
# W6.3c — paper-trader executor (exits / DCA / TP-ladder / followup)
# ============================================================
PAPER_TP_X=5.0
PAPER_SL_X=0
PAPER_TRAIL_DROP=0.5
PAPER_TRAIL_TRIGGER_X=1.3
# peak = трейл от пика после trailTriggerX; ladder_retrace = закрыть остаток при откате PnL до предыдущей ступени TP-ladder
PAPER_TRAIL_MODE=peak
PAPER_TIMEOUT_HOURS=12

# DCA: triggerPct(int %):addFraction, csv. Empty = off.
PAPER_DCA_LEVELS=
PAPER_DCA_KILLSTOP=0

# TP ladder: pnlFrac:sellFracOfRemaining, csv. Empty = off.
PAPER_TP_LADDER=

# TP grid (Paper Oscar-style): PnL step vs avg as fraction (0.05 = +5% each rung); sell fraction of current remainder.
# When PAPER_TP_GRID_STEP_PNL > 0, discrete PAPER_TP_LADDER is ignored at runtime.
PAPER_TP_GRID_STEP_PNL=0
PAPER_TP_GRID_SELL_FRACTION=0.2

PAPER_FOLLOWUP_OFFSETS_MIN=30,60,120
PAPER_FOLLOWUP_TICK_MS=30000

PAPER_CONTEXT_SWAPS=true
PAPER_CONTEXT_SWAPS_LIMIT=5
PAPER_PRE_ENTRY_DYNAMICS=true
PAPER_PEAK_LOG_STEP_PCT=1
PAPER_STATS_INTERVAL_MS=300000

