PAPER_POST_MIN_VOL_5M_USD=2500
PAPER_POST_MIN_BUYS_5M=16
PAPER_POST_MIN_SELLS_5M=10
PAPER_POST_MIN_AGE_MIN=25
PAPER_POST_MAX_AGE_MIN=180
PAPER_POST_MIN_BS=1.0

# Global gate
PAPER_MIN_TOKEN_AGE_MIN=0
PAPER_MIN_HOLDER_COUNT=0

# Dip detector
PAPER_DIP_LOOKBACK_MIN=60
