DIGEST_SEND_TELEGRAM=1

# hourly-telegram-report
HOURLY_COVERAGE_HOURS=1
HOURLY_TOP_N=4
POSITION_USD=100

# post-mortem (on-demand)
PM_WINDOW_HOURS=48

# ============================================================
# W8.0 — live-oscar (Phase 0+: отдельный процесс, см. W8.0_IMPLEMENTATION_PHASES.md)
# Rollback: не поднимать PM2 live-oscar или LIVE_STRATEGY_ENABLED=0.
# LIVE_TRADES_PATH обязан отличаться от журнала paper Oscar (LIVE_PARITY_PAPER_TRADES_PATH / PAPER_TRADES_PATH).
# ============================================================
LIVE_STRATEGY_ENABLED=0
LIVE_EXECUTION_MODE=dry_run
LIVE_STRATEGY_PROFILE=oscar
LIVE_STRATEGY_ID=live-oscar
LIVE_TRADES_PATH=/opt/solana-alpha/data/live/pt1-oscar-live.jsonl
LIVE_HEARTBEAT_INTERVAL_MS=60000
LIVE_PARITY_PAPER_TRADES_PATH=/opt/solana-alpha/data/paper2/pt1-oscar.jsonl
# LIVE_WALLET_SECRET — только при ENABLED=1 и simulate|live (путь к keypair, chmod 600)
# Опционально: fsync на каждый heartbeat live JSONL (дефолт выкл.)
# LIVE_JSONL_FSYNC_HEARTBEAT=0

# ============================================================
# W6.5 — three live dip strategies (DipRunner / Oscar / Dno)
# ============================================================
# Whale silence: capitulator only if last sell on this mint was ≥ N min ago.
# 0 = OFF. PM2 apps use 10.
PAPER_DIP_WHALE_SILENCE_MIN=10

# Heartbeat-based healthcheck tail scan (see scripts-tmp/paper2-healthcheck.mjs).
# PAPER2_MAX_STALE_MIN уже задан выше в блоке W6.4.
PAPER2_HEALTH_TAIL_LINES=1500
