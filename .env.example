# ===== Database =====
# Neon free tier: https://neon.tech (10GB free)
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solana_alpha

# ===== Redis (BullMQ queue) =====
# Upstash free: https://upstash.com (10k commands/day)
REDIS_URL=redis://localhost:6379

# ===== Helius =====
# Free tier: https://www.helius.dev (1M credits/mo)
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
# Public webhook URL where Helius will POST swap events (e.g. ngrok or prod domain)
HELIUS_WEBHOOK_URL=
# Webhook auth header secret (we generate locally, set in Helius dashboard)
HELIUS_WEBHOOK_AUTH=
#
# ===== Helius safety guard =====
# After the 2026-04 incident (1M free credits burned in ~1h by accidentally
# subscribing to entire DEX programs) ALL Helius access is gated.
#
# HELIUS_MODE values:
#   off      = code never calls Helius (default; safe).
#   wallets  = webhook subscribes to addresses from watchlist_wallets only.
#              backfill / RPC calls allowed within budget.
#   unsafe   = same as wallets but allows you to push the watchlist size cap.
#              still refuses to subscribe to known DEX programs.
HELIUS_MODE=off
# Hard daily ceiling on estimated credits (guard short-circuits beyond).
# Free tier = 1M/month, so a safe daily cap is roughly 30k.
HELIUS_DAILY_BUDGET=30000
# Hard monthly ceiling. Set well below your plan's quota to leave headroom.
HELIUS_MONTHLY_BUDGET=800000
# Maximum addresses we will ever pass to a single webhook subscription.
HELIUS_MAX_WATCHLIST_SIZE=500

# ===== Other data sources =====
# Birdeye: https://bds.birdeye.so/ (Starter plan free, ~30 req/min)
# Used by `npm run watchlist:seed` to discover smart-money wallets via top-traders
# of currently-hot SOL tokens. Required for seeding the Helius webhook subscription.
# Sign up takes ~30s, no credit card.
BIRDEYE_API_KEY=
# Solscan public API (no key needed, just rate limited)

# ===== API server =====
API_HOST=0.0.0.0
API_PORT=3000
LOG_LEVEL=info

# ===== Trading (only used at Stage 5 live pilot) =====
# DO NOT fill until live pilot. Path to JSON keypair file. NEVER commit.
WALLET_KEYPAIR_PATH=
# Hard cap on a single trade in USDC. Defaults to 50 if not set.
MAX_POSITION_USD=50
# Higher cap for high-conviction meta-hypotheses (H7 confluence gate). Defaults to 150.
MAX_POSITION_USD_HIGH_CONVICTION=150
# Daily kill-switch loss in % of trading capital
DAILY_LOSS_LIMIT_PCT=5

# ===== Telegram alerts (optional but strongly recommended) =====
# 1. Open @BotFather in Telegram, send /newbot, follow prompts -> copy token here
# 2. Send /start to your new bot from your personal Telegram account
# 3. Open https://api.telegram.org/bot<TOKEN>/getUpdates  -> find "chat":{"id":XXXXX}
# 4. Put that numeric id (can be negative for groups) into TELEGRAM_CHAT_ID
# 5. Test: npm run telegram:test  (you should receive "sa-runner Telegram link OK")
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Watchlist seeders (advanced discovery) =====
# Below knobs are read by the seeder scripts on demand. They are NOT validated
# at startup — set them only in the shell where you run the seeder, or here.
#
# Helius Smart-Money discovery v2:
#   npm run watchlist:seed:helius
# Pump-retro alpha (early buyers in 2x+ tokens):
#   npm run watchlist:seed:pump
# Long-form alpha (early buyers in tokens that grew over weeks):
#   npm run watchlist:seed:longform
# Wallet behavior deep-dive (classify rotation/scalper/sniper/real_trader):
#   npm run watchlist:deepdive
#
# Universe collection (wide token-pool dump for offline whale extraction):
#   npm run universe:collect
# Optional knobs:
#   UNIV_TARGET_TOKENS=100               # tokens to scan (cost: tokens*pages*100 credits)
#   UNIV_PAGES=5                         # Helius pages per token
#   UNIV_MIN_LIQ=10000                   # min on-chain liquidity USD
#   UNIV_MIN_VOL=20000                   # min 24h volume USD
#   UNIV_MIN_AGE_HOURS=2                 # skip pure launchpad tokens
#   UNIV_MAX_AGE_DAYS=30                 # skip mature low-rotation tokens
#   UNIV_OUT=cache/universe.json         # output path
#   UNIV_DRY_RUN=1                       # plan + budget check only
#
# H8 — Rotation network discovery (hidden alpha behind known alpha):
#   npm run watchlist:seed:rotation
# Optional knobs:
#   ROT_SEED_SOURCES=helius-seed,pump-seed,longform-seed
#   ROT_SEED_FILE=                       # newline-separated wallets, alternative to sources
#   ROT_SEED_LIMIT=80                    # max seed wallets to scan
#   ROT_TRANSFER_PAGES=2                 # Helius pages of TRANSFER history per seed
#   ROT_MIN_SOL_PER_EDGE=0.5             # anti-dust threshold
#   ROT_MIN_FUNDERS=1                    # set 2 to require multi-seed cross-funding
#   ROT_FAN_IN_CAP=                      # override auto CEX detection cap
#   ROT_VERIFY_TOP=200                   # candidates to deep-verify with swap history
#                                        # (raised from 80 — fan-in scoring favors HODL
#                                        # receivers, single-funder MEMECOIN-OPs land deep)
#   ROT_VERIFY_ALL=0                     # 1 = verify ALL candidates (cost: rawCands * pages * 100)
#   ROT_VERIFY_PAGES=1                   # swap pages per verified candidate
#   ROT_REQUIRE_SWAP_FOR_INSERT=1        # only insert candidates with verified swaps;
#                                        # parents bypass this and always insert via
#                                        # ROT_PROMOTE_PARENTS
#   ROT_LIMIT=200                        # max wallets to insert
#   ROT_DRY_RUN=1                        # show plan, do not write
#   ROT_PURGE_OLD=1                      # soft-delete prior rotation-seed entries
#   ROT_DUMP=cache/rot.json              # dump cache for free offline re-tuning
#   ROT_LOAD=cache/rot.json              # skip Helius, reuse cached data
#   ROT_ANTI_FLEET=1                     # collapse near-duplicate rotation accounts
#   ROT_BIDIRECTIONAL=1                  # also analyze INCOMING transfers (free, same Helius
#                                        # data); reveals parent operators + bidirectional hubs
#   ROT_MIN_PARENT_CHILDREN=2            # parent must fund >=N seeds to be flagged as operator
#   ROT_PROMOTE_PARENTS=1                # insert top parents as source='rotation-parent'
#                                        # (their treasury wallets are gold for tracking)
#   ROT_PARENT_LIMIT=50                  # max parents to insert
#   ROT_HUB_BONUS=30                     # score bonus for bidirectional hubs (candidate
#                                        # that is ALSO a parent of multiple seeds)
#   ROT_HUB_REQUIRES_SWAP=1              # only boost BI-HUB if candidate has 1+ own swap
#                                        # (default on; pass-through routers stay neutral)
#   ROT_DROP_ROUTERS=1                   # drop pass-through routers entirely (likely CEX
#                                        # hot wallets / aggregators we don't blacklist)
#   ROT_ROUTER_MIN_EDGES=5               # router detection: min funders == min children
#   ROT_ROUTER_MIN_SOL=50                # router detection: min total SOL throughput
#   ROT_MAX_STALE_DAYS=30                # drop wallets whose last swap is older than N days
#                                        # CRITICAL: ancient swap activity is not current alpha
#   ROT_MAX_FUNDING_AGE_NO_SWAP=14       # drop no-swap wallets funded > N days ago (abandoned)
#   ROT_DROP_PASSIVE_HUBS=1              # drop BI-HUB-passive (parents w/ 0 swaps) from
#                                        # rotation-seed (still kept as rotation-parent).
#                                        # Default ON: pass-through wallets are useless to copy
#   ROT_REQUIRE_SWAP=0                   # tight mode: drop ANY 0-swap candidate entirely
#                                        # (only pure traders survive, no "may deploy soon")
#   ROT_DROP_RETAIL_MICRO=1              # drop RETAIL-MICRO class wallets. RETAIL-MICRO is now
#                                        # narrow: ultra-tiny (<$5 avg) OR small avg + low conviction
#                                        # (<5 buys AND <2 mints). Active micro-snipers — small avg
#                                        # but many buys + multi-mint — are CLASS=MEMECOIN-OP (the
#                                        # micro-sniper operator pattern, GoorwtjW/CnjzwkRh) and
#                                        # are kept and BOOSTED, not dropped.
#   ROT_OPERATOR_CLUSTERING=0            # group candidates by (primary funder + funding size).
#                                        # Off by default — in practice multiple alpha-seeds
#                                        # independently fund deploy-wallets with similar amounts,
#                                        # which the algorithm misclusters
#   ROT_CLUSTER_AMOUNT_BUCKET=1.0        # funding-size bucket in SOL for clustering
#   ROT_CLUSTER_REP_ONLY=0               # 1 = keep only one representative per operator
#   ROT_INSPECT=Wallet1,Wallet2          # DEBUG: print full diagnostics for these wallets
#                                        # (even if they were filtered out earlier)

# ===== Copy-trader (paper) =====
# When the API server runs with HELIUS_MODE=wallets and a registered webhook,
# every SWAP coming from a watchlist wallet is fed into the copy-trader:
#
#   - First-N attribution: only the FIRST watchlist wallet to BUY a mint opens
#     a paper position. Every subsequent wallet is treated as follow-the-leader
#     noise and dropped (state lives in the `copy_seen_mints` table).
#   - Mirror exit: when the SAME wallet that opened a copy position SELLS the
#     same mint, the paper position is closed at the leader's fill price.
#   - Time-stop: `npm run copy:sweep` (cron every 30m) closes any copy position
#     older than 48h at last-known DexScreener/Jupiter price.
#
# Stake size is taken from MAX_POSITION_USD (default $50 per copy).
# Status snapshot:    npm run copy:status
# Re-register webhook with current watchlist: npm run webhook:register
#
# Telegram alerts (notifyCopyEntry / notifyCopyExit) are sent automatically
# when TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID are configured.

# ===== Scam-farm detective (Wallet Atlas) =====
# DB-first; review queue in `scam_farm_candidates`. Append log: SCAM_FARM_LOG_PATH
# Default: dry-run (no candidate rows), no atlas writes. Server after validation:
#   SCAM_FARM_DRY_RUN=0 SCAM_FARM_WRITE_ATLAS=1
# Optional JSON-RPC (QuickNode / any HTTPS Solana node): key only in server .env
#   SCAM_FARM_ENABLE_RPC=0
#   SCAM_FARM_RPC_BUDGET=20
#   SOLANA_RPC_HTTP_URL=https://....quiknode.pro/SECRET/
#   (alias: QUICKNODE_HTTP_URL or legacy ALCHEMY_HTTP_URL)
# QuickNode credit meter + Telegram at 5% of monthly budget (80M default):
#   QUICKNODE_MONTHLY_CREDIT_BUDGET=80000000
#   QUICKNODE_ALERT_PCT=5   # шаг: Telegram при 5%, 10%, 15% … 100% использованного лимита
#   QUICKNODE_USAGE_PATH=data/quicknode-usage.json
#   TELEGRAM_BOT_TOKEN=  TELEGRAM_CHAT_ID=  (set QUICKNODE_TELEGRAM_ALERTS=0 to disable)
# Seed `tokens` from DexScreener (no RPC):  npm run tokens:seed:dex
# Signatures Seed (Шаг 1 гибрида free+QuickNode):
#   1) cron: npm run sigseed:enqueue   (ENQ_BATCH=30 ENQ_MAX_AGE_HOURS=48)
#   2) pm2:  npm run sigseed:worker    (SIGSEED_DAILY_CREDIT_CAP=2500000)
# meter учитывает каждый успешный RPC — Telegram-лесенка 5/10/15% сработает по факту.
# rpc-collector гибрид (Шаг 2): public по умолчанию, QuickNode только при 429/5xx.
#   PUBLIC_RPC_URL=https://solana-rpc.publicnode.com
#   RPC_COLLECTOR_QN_DAILY_CREDIT_CAP=500000
# PumpSwap-коллектор (Шаг 3): пишет pumpswap_pair_snapshots из DexScreener.
#   PUMPSWAP_COLLECTOR_INTERVAL_MS=60000   PUMPSWAP_ENQUEUE_RPC=1
# Backfill RotatingRpc 429-алёрт (Шаг 8):
#   BACKFILL_RPC_429_WINDOW_MS=300000  BACKFILL_RPC_429_THRESHOLD=25  BACKFILL_RPC_429_COOLDOWN_MS=1800000
# PM2 (salpha): npm run scam-farm:loop   # or cron: 0 */4 * * * cd /opt/solana-alpha && npm run scam-farm:detect
SCAM_FARM_DRY_RUN=1
SCAM_FARM_WRITE_ATLAS=0
SCAM_FARM_LOOKBACK_DAYS=14
SCAM_FARM_FUNDING_WINDOW_SEC=300
SCAM_FARM_FUNDING_MIN_TARGETS=3
SCAM_FARM_FUNDING_AMOUNT_TOLERANCE=0.2
SCAM_FARM_ORCH_MAX_AGE_H=120
SCAM_FARM_RUG_EARLY_BUYERS=40
SCAM_FARM_RUG_MIN_LIQ_USD=500
SCAM_FARM_STRONG_SCORE=80
# Min score to write Wallet Atlas when WRITE_ATLAS=1 (server often 30)
SCAM_FARM_CONFIRM_WRITE_SCORE=75
# 1 = write tags/clusters for needs_evidence when score >= CONFIRM (full automation)
SCAM_FARM_ATLAS_WRITE_BELOW_CONFIRMED=1
SCAM_FARM_DISMISS_STALE_DAYS=14
SCAM_FARM_DISMISS_MAX_SCORE=15
SCAM_FARM_ENABLE_RPC=0
SCAM_FARM_RPC_BUDGET=20
SCAM_FARM_UPDATE_PRIMARY=0
SCAM_FARM_MAX_SQL_ROWS=2000
SCAM_FARM_LOG_PATH=data/logs/scam-farm-detective.log
# SCAM_FARM: ежедневный Telegram-дайджест — флаги SCAM_FARM_DAILY_* в crontab, не в .env
# SCAM_FARM_CRON=0 */4 * * *

# ===== Mode flags =====
# paper | live - global execution mode
EXECUTOR_MODE=paper
