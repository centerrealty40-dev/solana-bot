# ------------------------------------------------------------
# Dashboard HTTP Basic Auth (W7.1.1 — restored)
# ------------------------------------------------------------
# Если оба значения непустые — dashboard-organizer-paper включает Basic Auth
# на ВСЕХ маршрутах кроме /api/health (используется внешним uptime-чеком).
# Если хотя бы одно пустое — auth отключён (legacy-поведение).
DASHBOARD_BASIC_USER=
DASHBOARD_BASIC_PASSWORD=
DASHBOARD_BASIC_REALM=Solana Alpha Dashboard
# Опционально: секрет подписи cookie сессии дашборда (≥16 символов); иначе деривируется от user+pass.
# DASHBOARD_SESSION_SECRET=
# DASHBOARD_COOKIE_SECURE=0 — выключить флаг Secure у cookie (локальный HTTP без TLS).

# Опционально: CoinGecko Pro API key для `/api/paper2/crypto-ticker` (иначе публичный api.coingecko.com).
# COINGECKO_API_KEY=

# Telegram. ОБЯЗАТЕЛЬНО для hourly-report, advisor, healthcheck.
# Единственный источник для всех скриптов — /opt/solana-alpha/.env (грузится через `import 'dotenv/config'`).
# НЕ дублировать в .env.hourly или других файлах — legacy .env.hourly игнорируется.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram cooldown / quiet (опционально, см. scripts/lib/telegram.mjs)
TELEGRAM_QUIET_FROM=
TELEGRAM_QUIET_TO=
TELEGRAM_COOLDOWN_HEALTH_PLATFORM_MS=600000
TELEGRAM_COOLDOWN_REPORT_STRATEGIES_MS=
TELEGRAM_COOLDOWN_ADVICE_PAPER2_MS=
TELEGRAM_COOLDOWN_ADVICE_DIGEST_MS=
TELEGRAM_COOLDOWN_PATH=/opt/solana-alpha/data/telegram-cooldown.json

# paper2-healthcheck
PAPER2_MAX_STALE_MIN=20
PAPER2_HEALTH_TELEGRAM_ON_ALERT=1
PAPER2_HEALTH_TELEGRAM_ON_OK=0

# paper2-advisor
PAPER2_ADVISOR_MIN_TRADES=12
PAPER2_ADVISOR_OUT=/opt/solana-alpha/data/paper2/advisor-latest.json

# advisor-digest
ADVISOR_DIR=/opt/solana-alpha/data/advisor
DIGEST_WINDOW_HOURS=24
DIGEST_TOP_N=6
DIGEST_SEND_TELEGRAM=1

# hourly-telegram-report (Coverage + Health + Live Oscar PnL + Eval + wallet + failed txs)
# HOURLY_DETAIL=1 — отладочный вывод списка paper JSONL в stderr
HOURLY_COVERAGE_HOURS=1
HOURLY_TOP_N=4
POSITION_USD=100
# Журнал live (по умолчанию LIVE_TRADES_PATH или data/live/pt1-oscar-live.jsonl)
# HOURLY_LIVE_JSONL=/opt/solana-alpha/data/live/pt1-oscar-live.jsonl
# Paper Oscar JSONL для счётчика Eval (pass за час)
# HOURLY_OSCAR_EVAL_JSONL=/opt/solana-alpha/data/paper2/pt1-oscar.jsonl
# HOURLY_LIVE_STRATEGY_ID=live-oscar
# Баланс кошелька в hourly: RPC и pubkey (fallback LIVE_WALLET_PUBKEY)
# HOURLY_RPC_URL= — иначе берётся SA_RPC_HTTP_URL / SA_RPC_URL (на VPS обычно задан SA_RPC_HTTP_URL)
# HOURLY_WALLET_PUBKEY= — иначе LIVE_WALLET_PUBKEY из этого же .env (нужно для баланса SOL/USDC в hourly Telegram)

# post-mortem (on-demand)
PM_WINDOW_HOURS=48

# ============================================================
# W8.0 — live-oscar (Phase 0+: отдельный процесс, см. W8.0_IMPLEMENTATION_PHASES.md)
# Rollback: не поднимать PM2 live-oscar или LIVE_STRATEGY_ENABLED=0.
# LIVE_TRADES_PATH обязан отличаться от журнала paper Oscar (LIVE_PARITY_PAPER_TRADES_PATH / PAPER_TRADES_PATH).
# ============================================================
LIVE_STRATEGY_ENABLED=0
LIVE_EXECUTION_MODE=dry_run
LIVE_STRATEGY_PROFILE=oscar
LIVE_STRATEGY_ID=live-oscar
LIVE_TRADES_PATH=/opt/solana-alpha/data/live/pt1-oscar-live.jsonl
LIVE_HEARTBEAT_INTERVAL_MS=60000
LIVE_PARITY_PAPER_TRADES_PATH=/opt/solana-alpha/data/paper2/pt1-oscar.jsonl
# Phase 4: загрузить fragment с baseline `PAPER_*` (отдельный файл от канарейки pt1-oscar; см. W8.0-p4 §3.3.1)
# LIVE_INHERIT_ENV_FILE=/opt/solana-alpha/data/env/live-oscar-baseline.env
# На live-oscar держите PAPER_DRY_RUN=0 иначе конвейер входа до гейтов не выполняется.
# W7.4 / W7.4.2: для PM2 `live-oscar` дефолты в ecosystem.config.cjs (pre-entry + pre-exit, пороги как pt1-oscar).
# LIVE_WALLET_SECRET — только при ENABLED=1 и simulate|live (путь к файлу: JSON-массив байт Solana CLI или одна строка base58 из Phantom)
# LIVE_WALLET_PUBKEY= — опционально: ожидаемый публичный адрес; при несовпадении с ключом из файла процесс не стартует.
# Сид-фразу в git/env не класть; восстановите keypair локально и загрузите файл на VPS.
# Опционально: fsync на каждый heartbeat live JSONL (дефолт выкл.)
# LIVE_JSONL_FSYNC_HEARTBEAT=0

# W8.0 Phase 2 — Jupiter lite-api (quote + unsigned swap body)
# LIVE_JUPITER_QUOTE_URL=https://lite-api.jup.ag/swap/v1/quote
# LIVE_JUPITER_SWAP_URL=https://lite-api.jup.ag/swap/v1/swap
# LIVE_JUPITER_QUOTE_TIMEOUT_MS=5000
# LIVE_JUPITER_SWAP_TIMEOUT_MS=8000
# LIVE_DEFAULT_SLIPPAGE_BPS=400
# LIVE_QUOTE_MAX_AGE_MS=8000 — по умолчанию в коде 8000 мс, если переменная не задана; 0 = выключить гейт; верхняя граница парсера 600000 (W8.0 §10)
# JUPITER_API_KEY= — опционально для лимитов Pro
# Одноразовый смок после live_boot (не для прод без контроля лимитов):
# LIVE_PHASE2_JUPITER_SELF_TEST=0
# LIVE_PHASE2_SELF_TEST_MINT=
# LIVE_PHASE2_SELF_TEST_SIZE_USD=1
# LIVE_PHASE2_SOL_USD=150
# LIVE_PHASE2_USER_PUBKEY= — иначе детерминированный placeholder (не для send)

# W8.0 Phase 3 — sign + simulateTransaction (QuickNode via SA_RPC_HTTP_URL; feature sim)
# LIVE_SIM_ENABLED=1
# LIVE_SIM_TIMEOUT_MS=12000
# LIVE_SIM_CREDITS_PER_CALL=30
# LIVE_SIM_REPLACE_RECENT_BLOCKHASH=1
# LIVE_SIM_SIG_VERIFY=0
# Опциональный смок: quote → build → sign → simulate (требует SA_RPC_HTTP_URL, mint, кошелёк):
# LIVE_PHASE3_SIM_SELF_TEST=0
# LIVE_PHASE3_SELF_TEST_MINT=
# LIVE_PHASE3_SELF_TEST_SIZE_USD=1
# LIVE_PHASE3_SOL_USD=150

# W8.0 Phase 5 — §3.3 risk / §3.4 capital (переменная не задана ⇒ проверка выключена; см. CHANGELOG 1.8.0)
# LIVE_MAX_POSITION_USD=
# LIVE_MAX_OPEN_POSITIONS=
# LIVE_MAX_STRATEGY_LOSS_USD=
# LIVE_KILL_AFTER_CONSEC_FAIL=0
# LIVE_HALT_CLOSE_ALL_ON_MAX_LOSS=0
# LIVE_MIN_WALLET_SOL=
# LIVE_ENTRY_NOTIONAL_USD=
# LIVE_ENTRY_MIN_FREE_MULT=2
# LIVE_CAPITAL_ROTATE_CASCADE=0
# LIVE_FREE_SOL_BUFFER_LAMPORTS=10000000

# W8.0 Phase 6 — sendTransaction + confirm (см. CHANGELOG 1.9.0; канарейка: не включать live без лимитов §3.3–§3.4)
# LIVE_CONFIRM_COMMITMENT=confirmed
# LIVE_CONFIRM_TIMEOUT_MS=60000
# LIVE_SEND_SKIP_PREFLIGHT=0
# LIVE_SIM_BEFORE_SEND=1
# LIVE_SEND_MAX_RETRIES=2
# LIVE_SEND_RETRY_BASE_MS=500
# LIVE_SEND_CREDITS_PER_CALL=30
# LIVE_SEND_RPC_TIMEOUT_MS=25000
# LIVE_RPC_HTTP_URL= — опционально: отдельный RPC только для send/confirm (иначе SA_RPC_HTTP_URL)
# QN_FEATURE_BUDGET_LIVE_SEND=4000000

# W8.0 Phase 7 — replay live_position_* + reconcile SPL (CHANGELOG 1.11.4)
# LIVE_REPLAY_ON_BOOT=1
# LIVE_REPLAY_MAX_FILE_BYTES=26214400 — если файл журнала больше, replay только хвост (см. RUNBOOK_LIVE_OSCAR_PHASE7.md)
# LIVE_REPLAY_TAIL_LINES= — опционально: только последние N строк журнала
# LIVE_REPLAY_SINCE_TS= — опционально: только события с ts ≥ (unix ms)
# LIVE_RECONCILE_ON_BOOT=1
# LIVE_RECONCILE_MODE=block_new — report | block_new | trust_chain (trust_chain только с LIVE_RECONCILE_TRUST_CHAIN_ALLOWED=1)
# LIVE_RECONCILE_TRUST_CHAIN_ALLOWED=0
# LIVE_RECONCILE_TOLERANCE_ATOMS=10000
# LIVE_RECONCILE_TX_SAMPLE_N=0 — последние N confirmed tx из журнала → getTransaction (0 = выкл.; см. RUNBOOK_LIVE_OSCAR_PHASE7 §9)

# W8.0-p7.1 — цепочные якоря в журнале + паритет paper/live notional (CHANGELOG 1.11.23; RUNBOOK §12)
# LIVE_REPLAY_TRUST_GHOST_POSITIONS=0 — 1 = применять live_position_* без entryLegSignatures (опасно; только ручной режим)
# LIVE_STRICT_NOTIONAL_PARITY=1 — live: PAPER_POSITION_USD vs LIVE_ENTRY_NOTIONAL_USD / LIVE_MAX_POSITION_USD
# LIVE_ANCHOR_VERIFY_ON_BOOT=1 — live: проверка entryLegSignatures через getTransaction перед SPL reconcile

# Phase 7 дополнение — восстановление live_position_* если buy попал в блок, а журнал пометил execution_result как failed (confirm_timeout и т.п.)
# LIVE_REPAIR_MISSED_OPENS=1 — по умолчанию в коде включено; 0|false выключает проход при старте live-oscar
# LIVE_REPAIR_MISSED_OPEN_MAX_AGE_MS=604800000 — семь суток (не задано ⇒ то же значение по умолчанию)

# ============================================================
# W6.5 — three live dip strategies (DipRunner / Oscar / Dno)
# ============================================================
# Whale silence: capitulator only if last sell on this mint was ≥ N min ago.
# 0 = OFF. PM2 apps use 10.
PAPER_DIP_WHALE_SILENCE_MIN=10

# Heartbeat-based healthcheck tail scan (see scripts-tmp/paper2-healthcheck.mjs).
# PAPER2_MAX_STALE_MIN уже задан выше в блоке W6.4.
PAPER2_HEALTH_TAIL_LINES=1500
