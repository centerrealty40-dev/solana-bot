# === solana-alpha v2 (post-W2 slim) ===

# --- Database ---
# Preferred new name (matches ops docs). Legacy alias: DATABASE_URL (still supported in code).
SA_PG_DSN=postgresql://salpha:CHANGE_ME@localhost:5432/solana_alpha

# --- Redis (required by src/core/config.ts when any code imports DB/logger chain) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Solana RPC (paid endpoint, used by scam-farm-detective и future sa-stream) ---
SA_RPC_URL=https://api.mainnet-beta.solana.com
SA_RPC_FALLBACK_URLS=

# --- Telegram alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Dashboard ---
HOST=0.0.0.0
PORT=3008
STORE_PATH=/opt/solana-alpha/data/paper2/organizer-paper.jsonl

# --- Cloudflare R2 (daily atlas backup) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# --- Scam-farm detective (reference run, off by default) ---
SCAM_FARM_LOOKBACK_DAYS=14
SCAM_FARM_WRITE_ATLAS=0

# --- QuickNode billing (qn-client W7.1 + sa-parser-style reserve) ---
QUICKNODE_MONTHLY_CREDIT_BUDGET=80000000
QUICKNODE_DAILY_CREDIT_BUDGET=3000000
QUICKNODE_DAILY_ENFORCE=1
# Hourly cap (UTC hour). 0 or unset = disabled.
QUICKNODE_HOURLY_CREDIT_BUDGET=0
QUICKNODE_CREDITS_PER_SOLANA_RPC=30
# QUICKNODE_USAGE_PATH=data/quicknode-usage.json
# Per-feature monthly sub-budgets (rolling UTC month).
QN_FEATURE_BUDGET_SAFETY=1000000
QN_FEATURE_BUDGET_PRI_FEE=2000000
QN_FEATURE_BUDGET_PRICE_VERIFY=4000000
QN_FEATURE_BUDGET_SIM=6000000
QN_FEATURE_BUDGET_LIQ_WATCH=12000000
# W7.6 live SPL holders resolver (papertrader)
QN_FEATURE_BUDGET_HOLDERS=10000000
# QN_FEATURE_USAGE_PATH=data/qn-feature-usage.json
# Provider daily cache (optional; sa-stream off): QUICKNODE_DAILY_ENFORCE_PROVIDER=0

# --- Streaming ingest (sa-stream) ---
# HTTPS JSON-RPC base (QuickNode example). Falls back to QUICKNODE_HTTP_URL then HELIUS_RPC_URL if unset.
SA_RPC_HTTP_URL=
# Optional explicit WSS; if empty, derived from SA_RPC_HTTP_URL (https→wss).
SA_RPC_WS_URL=
SA_STREAM_PROGRAM_IDS=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
SA_STREAM_COMMITMENT=confirmed
SA_STREAM_BATCH_SIZE=50
SA_STREAM_BATCH_MS=1000
SA_STREAM_RECONNECT_MIN_MS=1000
SA_STREAM_RECONNECT_MAX_MS=30000
SA_STREAM_LOG_EVERY_N=500

# --- Parser (sa-parser) ---
SA_PARSER_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
SA_PARSER_BATCH_SIZE=25
SA_PARSER_TICK_MS=1500
SA_PARSER_RPC_BATCH=5
SA_PARSER_RPC_TIMEOUT_MS=8000
SA_PARSER_LOOKBACK_HOURS=6
SA_PARSER_MAX_INFLIGHT=2
SA_PARSER_LOG_EVERY_N=200
SA_PARSER_DRY_RUN=false
# TODO(W4.1): replace with live SOL/USD feed.
SA_SOL_USD_FALLBACK=150.0

# --- Atlas writes (sa-atlas) ---
SA_ATLAS_BATCH_SIZE=200
SA_ATLAS_TICK_MS=1500
SA_ATLAS_LOOKBACK_HOURS=12
SA_ATLAS_LOG_EVERY_N=1000
SA_ATLAS_TAG_WINDOW_HOURS=24
SA_ATLAS_FLOWS_ENABLED=true
SA_ATLAS_TAGS_ENABLED=true
SA_ATLAS_DRY_RUN=false

# ===== W6.1 — DEX collectors =====
# All collectors use sane defaults; override only if needed.

# Raydium / Meteora / Orca / Moonshot collectors (DexScreener + GeckoTerminal):
RAYDIUM_COLLECTOR_INTERVAL_MS=60000
METEORA_COLLECTOR_INTERVAL_MS=60000
ORCA_COLLECTOR_INTERVAL_MS=60000
MOONSHOT_COLLECTOR_INTERVAL_MS=60000

# Jupiter route watcher:
JUPITER_WATCHER_INTERVAL_MS=60000
JUPITER_WATCHER_LOOKBACK_HOURS=2
JUPITER_WATCHER_MAX_MINTS=20
JUPITER_WATCHER_QUOTE_IN_USD=25
JUPITER_WATCHER_SLIPPAGE_BPS=300
# CRITICAL: must be '0' until W6.7 (rpc_tasks table not created yet).
JUPITER_WATCHER_ENQUEUE_RPC=0

# Direct-LP detector:
DIRECT_LP_DETECTOR_INTERVAL_MS=60000
DIRECT_LP_FRESH_LOOKBACK_MINUTES=10
DIRECT_LP_HISTORY_LOOKBACK_HOURS=168
DIRECT_LP_MIN_LIQUIDITY_USD=0
# CRITICAL: must be '0' until W6.7 (rpc_tasks table not created yet).
DIRECT_LP_ENQUEUE_RPC=0

# ============================================================
# W6.3a — paper-trader skeleton
# ============================================================
PAPER_STRATEGY_ID=pt1-skeleton-test
PAPER_STRATEGY_KIND=fresh
PAPER_TRADES_PATH=/opt/solana-alpha/data/paper2/pt1-skeleton-test.jsonl

PAPER_DISCOVERY_INTERVAL_MS=10000
PAPER_TRACK_INTERVAL_MS=30000
PAPER_FOLLOWUP_TICK_MS=30000
PAPER_HEARTBEAT_INTERVAL_MS=10000
PAPER_SOL_PRICE_REFRESH_MS=300000
PAPER_BTC_CONTEXT_REFRESH_MS=300000

PAPER_POSITION_USD=100

# BTC context (wrapped-BTC mints in swaps table)
# PAPER_BTC_MINTS=9n4nbM75f5Ui33ZbPYXn59EwSgE8CGsHtAeTH5YFeJ9E,3NZ9JMVBmGAqocybic2c7LQCJScmgsAZ6vQqTDzcqmJh,7vfCXTUXx5WJV5JADk17DUJ4ksgau7utNKj4b963voxs

PAPER_FEE_BPS_PUMPFUN=100
PAPER_FEE_BPS_PUMPSWAP=30
PAPER_FEE_BPS_RAYDIUM=25
PAPER_FEE_BPS_ORCA=10
PAPER_FEE_BPS_METEORA=20
PAPER_FEE_BPS_MOONSHOT=100
PAPER_SLIP_BASE_BPS_PUMPFUN=200
PAPER_SLIP_BASE_BPS_PUMPSWAP=50
PAPER_SLIP_BASE_BPS_RAYDIUM=50
PAPER_SLIP_BASE_BPS_ORCA=50
PAPER_SLIP_BASE_BPS_METEORA=50
PAPER_SLIP_BASE_BPS_MOONSHOT=150
PAPER_SLIP_LIQUIDITY_COEF=1.0
PAPER_NETWORK_FEE_USD=0.05
PAPER_FILL_RATE_PCT=100

PAPER_FEE_BPS_PER_SIDE=100
PAPER_SLIPPAGE_BPS_PER_SIDE=200

PAPER_DRY_RUN=true

# ------------------------------------------------------------
# W7.2 — Pre-entry safety (QuickNode feature `safety`) + live mcap TTL
# Canary: enable only per-strategy in ecosystem.config.cjs (pt1-dno first).
# ------------------------------------------------------------
PAPER_SAFETY_CHECK_ENABLED=0
PAPER_SAFETY_TOP_HOLDER_MAX_PCT=40
PAPER_SAFETY_REQUIRE_MINT_AUTH_NULL=1
PAPER_SAFETY_REQUIRE_FREEZE_AUTH_NULL=1
PAPER_SAFETY_TIMEOUT_MS=2500
PAPER_LIVE_MCAP_TTL_MS=30000

# ------------------------------------------------------------
# W7.3 — Priority fee monitor (qnCall feature `pri_fee`, shared disk cache)
# Rollback: PAPER_PRIORITY_FEE_ENABLED=0 (fallback = PAPER_NETWORK_FEE_USD).
# ------------------------------------------------------------
PAPER_PRIORITY_FEE_ENABLED=0
PAPER_PRIORITY_FEE_TICKER_MS=60000
PAPER_PRIORITY_FEE_MAX_AGE_MS=600000
PAPER_PRIORITY_FEE_RPC_TIMEOUT_MS=2500
PAPER_PRIORITY_FEE_PERCENTILE=p75
PAPER_PRIORITY_FEE_TARGET_CU=200000
PAPER_PRIORITY_FEE_CACHE_PATH=data/priority-fee-cache.json

# ------------------------------------------------------------
# W7.4 — Pre-entry price verification (Jupiter quote sanity check)
# Rollback: PAPER_PRICE_VERIFY_ENABLED=0 (no quote calls, no jsonl stamping).
# Shadow: ENABLED=1, BLOCK_ON_FAIL=0 (verdict stamped; opens still proceed).
# Optional: USE_JUPITER_PRICE=1 sets effective entry to Jupiter-implied price.
# ------------------------------------------------------------
PAPER_PRICE_VERIFY_ENABLED=0
PAPER_PRICE_VERIFY_BLOCK_ON_FAIL=0
PAPER_PRICE_VERIFY_USE_JUPITER_PRICE=0
PAPER_PRICE_VERIFY_MAX_SLIP_PCT=4.0
PAPER_PRICE_VERIFY_MAX_SLIP_BPS=400
PAPER_PRICE_VERIFY_MAX_PRICE_IMPACT_PCT=8.0
PAPER_PRICE_VERIFY_TIMEOUT_MS=2500

# ------------------------------------------------------------
# W7.8 — On-chain simulate audit (Jupiter unsigned swap + qnCall feature `sim`, stamped on `open`)
# Rollback: PAPER_SIM_AUDIT_ENABLED=0 (no QuickNode simulate, no jsonl simAudit field).
# Canary: ENABLED=1, SAMPLE_PCT=5..10; SA_RPC_HTTP_URL required for qnCall.
# ------------------------------------------------------------
PAPER_SIM_AUDIT_ENABLED=0
PAPER_SIM_SAMPLE_PCT=0
PAPER_SIM_MAX_WALL_MS=8000
PAPER_SIM_BUILD_TIMEOUT_MS=5000
PAPER_SIM_USE_JUPITER_BUILD=1
PAPER_SIM_CREDS_PER_CALL=30
PAPER_SIM_STRICT_BUDGET=1

# ------------------------------------------------------------
# W7.5 — Liquidity drain watch (pool liq vs entry baseline; DB snapshots first)
# Rollback: PAPER_LIQ_WATCH_ENABLED=0 (no snapshot reads for liq-watch in tracker).
# Shadow: ENABLED=1 + FORCE_CLOSE=0 (verdict computed; no force-close).
# Production: ENABLED=1 + FORCE_CLOSE=1.
# ------------------------------------------------------------
PAPER_LIQ_WATCH_ENABLED=0
PAPER_LIQ_WATCH_FORCE_CLOSE=0
PAPER_LIQ_WATCH_DRAIN_PCT=35
PAPER_LIQ_WATCH_MIN_AGE_MIN=1
PAPER_LIQ_WATCH_CONSECUTIVE_FAILURES=2
PAPER_LIQ_WATCH_SNAPSHOT_MAX_AGE_MS=120000
PAPER_LIQ_WATCH_RPC_FALLBACK=0
PAPER_LIQ_WATCH_STAMP_ON_ALL_CLOSE=1
PAPER_LIQ_WATCH_STAMP_ON_TRACK=0

# ------------------------------------------------------------
# W7.6 — Live SPL holders resolver via QuickNode (papertrader)
# Решает проблему пустого tokens.holder_count: запрос QN getProgramAccounts с фильтром
# по mint и dataSlice(owner+amount), уникальные owners с ненулевым балансом.
# Включается per-strategy в ecosystem.config.cjs (pt1-diprunner первым).
# Rollback: PAPER_HOLDERS_LIVE_ENABLED=0 → ладдер вернётся к старому опросу tokens.holder_count.
# ------------------------------------------------------------
PAPER_HOLDERS_LIVE_ENABLED=0
PAPER_HOLDERS_USE_QN_ADDON=0
PAPER_HOLDERS_TTL_MS=90000
PAPER_HOLDERS_NEG_TTL_MS=15000
PAPER_HOLDERS_MAX_PER_TICK=10
PAPER_HOLDERS_TIMEOUT_MS=4000
PAPER_HOLDERS_INCLUDE_TOKEN2022=1
PAPER_HOLDERS_EXCLUDE_OWNERS=
# block | warn | db_fallback (по умолчанию db_fallback)
PAPER_HOLDERS_ON_FAIL=db_fallback
PAPER_HOLDERS_DB_WRITEBACK=0
PAPER_HOLDERS_GPA_CREDITS_PER_CALL=100

# ============================================================
# W6.3b — discovery / filters / dip / whale
# ============================================================
PAPER_ENABLE_LAUNCHPAD_LANE=false
PAPER_ENABLE_MIGRATION_LANE=true
PAPER_ENABLE_POST_LANE=true

