# Решает проблему пустого tokens.holder_count: запрос QN getProgramAccounts с фильтром
# по mint и dataSlice(owner+amount), уникальные owners с ненулевым балансом.
# Включается per-strategy в ecosystem.config.cjs (pt1-diprunner первым).
# Rollback: PAPER_HOLDERS_LIVE_ENABLED=0 → ладдер вернётся к старому опросу tokens.holder_count.
# ------------------------------------------------------------
PAPER_HOLDERS_LIVE_ENABLED=0
PAPER_HOLDERS_USE_QN_ADDON=0
PAPER_HOLDERS_TTL_MS=90000
PAPER_HOLDERS_NEG_TTL_MS=15000
