PAPER_PRICE_VERIFY_CIRCUIT_SKIP_RATE_PCT=10
PAPER_PRICE_VERIFY_CIRCUIT_MIN_ATTEMPTS=12
PAPER_PRICE_VERIFY_CIRCUIT_COOLDOWN_MS=90000
# W7.4.2 — pre-exit (tracker partial/full sell vs Jupiter mint→SOL); thresholds reuse row above.
# Rollback: PAPER_PRICE_VERIFY_EXIT_ENABLED=0
PAPER_PRICE_VERIFY_EXIT_ENABLED=0
PAPER_PRICE_VERIFY_EXIT_BLOCK_ON_FAIL=0

# ------------------------------------------------------------
# W7.8 — On-chain simulate audit (Jupiter unsigned swap + qnCall feature `sim`, stamped on `open`)
# Rollback: PAPER_SIM_AUDIT_ENABLED=0 (no QuickNode simulate, no jsonl simAudit field).
# Canary: ENABLED=1, SAMPLE_PCT=5..10; SA_RPC_HTTP_URL required for qnCall.
# ------------------------------------------------------------
PAPER_SIM_AUDIT_ENABLED=0
PAPER_SIM_SAMPLE_PCT=0
PAPER_SIM_MAX_WALL_MS=8000
PAPER_SIM_BUILD_TIMEOUT_MS=5000
PAPER_SIM_USE_JUPITER_BUILD=1
PAPER_SIM_CREDS_PER_CALL=30
PAPER_SIM_STRICT_BUDGET=1

# ------------------------------------------------------------
# W7.5 — Liquidity drain watch (pool liq vs entry baseline; DB snapshots first)
# Rollback: PAPER_LIQ_WATCH_ENABLED=0 (no snapshot reads for liq-watch in tracker).
# Shadow: ENABLED=1 + FORCE_CLOSE=0 (verdict computed; no force-close).
# Production: ENABLED=1 + FORCE_CLOSE=1.
# ------------------------------------------------------------
PAPER_LIQ_WATCH_ENABLED=0
PAPER_LIQ_WATCH_FORCE_CLOSE=0
PAPER_LIQ_WATCH_DRAIN_PCT=35
PAPER_LIQ_WATCH_MIN_AGE_MIN=1
PAPER_LIQ_WATCH_CONSECUTIVE_FAILURES=2
PAPER_LIQ_WATCH_SNAPSHOT_MAX_AGE_MS=120000
PAPER_LIQ_WATCH_RPC_FALLBACK=0
PAPER_LIQ_WATCH_STAMP_ON_ALL_CLOSE=1
PAPER_LIQ_WATCH_STAMP_ON_TRACK=0

# ------------------------------------------------------------
