PAPER_DIP_MAX_DROP_PCT=-45
PAPER_DIP_MIN_IMPULSE_PCT=20
PAPER_DIP_MIN_AGE_MIN=25
PAPER_DIP_COOLDOWN_MIN=120
PAPER_DIP_COOLDOWN_MIN_SCALP=20

# Whale analysis (default OFF; вкл при запуске Oscar/Dno в W6.5)
PAPER_DIP_WHALE_ANALYSIS_ENABLED=0
PAPER_DIP_REQUIRE_WHALE_TRIGGER=0
PAPER_DIP_LARGE_SELL_USD=3000
PAPER_DIP_RECENT_LOOKBACK_MIN=10
PAPER_DIP_CAPITULATION_PCT=0.7
PAPER_DIP_GROUP_SELL_USD=5000
PAPER_DIP_GROUP_MIN_SELLERS=2
PAPER_DIP_GROUP_DUMP_PCT=0.4
PAPER_DIP_BLOCK_CREATOR_DUMP=true
PAPER_DIP_CREATOR_DUMP_LOOKBACK_MIN=20
PAPER_DIP_CREATOR_DUMP_MIN_PCT=0.05
PAPER_DIP_CREATOR_DUMP_MAX_PCT=0.6
PAPER_DIP_DCA_PRED_MIN_SELLS_24H=4
PAPER_DIP_DCA_PRED_MIN_INTERVAL_MIN=30
PAPER_DIP_DCA_PRED_MIN_CHUNK_USD=3000
PAPER_DIP_DCA_AGGR_MIN_SELLS_24H=6
PAPER_DIP_DCA_AGGR_MAX_INTERVAL_MIN=15

# Legacy launchpad filters (used only when PAPER_ENABLE_LAUNCHPAD_LANE=true; W6.3b stub returns [])
PAPER_MIN_UNIQUE_BUYERS=20
PAPER_MIN_BUY_SOL=5
PAPER_MIN_BUY_SELL_RATIO=1.5
PAPER_MAX_TOP_BUYER_SHARE=0.35
PAPER_MIN_BC_PROGRESS=0.25
PAPER_MAX_BC_PROGRESS=0.95
PAPER_DECISION_AGE_MIN=7
PAPER_DECISION_AGE_MAX_MIN=12
PAPER_WINDOW_START_MIN=2
PAPER_BC_GRADUATION_SOL=85

# ============================================================
# W6.3c — paper-trader executor (exits / DCA / TP-ladder / followup)
# ============================================================
PAPER_TP_X=5.0
PAPER_SL_X=0
PAPER_TRAIL_DROP=0.5
PAPER_TRAIL_TRIGGER_X=1.3
# peak = трейл от пика после trailTriggerX; ladder_retrace = закрыть остаток при откате PnL до предыдущей ступени TP-ladder
PAPER_TRAIL_MODE=peak
PAPER_TIMEOUT_HOURS=12

# DCA: triggerPct(int %):addFraction, csv. Empty = off.
PAPER_DCA_LEVELS=
PAPER_DCA_KILLSTOP=0

# TP ladder: pnlFrac:sellFracOfRemaining, csv. Empty = off.
PAPER_TP_LADDER=

PAPER_FOLLOWUP_OFFSETS_MIN=30,60,120
PAPER_FOLLOWUP_TICK_MS=30000

PAPER_CONTEXT_SWAPS=true
PAPER_CONTEXT_SWAPS_LIMIT=5
PAPER_PRE_ENTRY_DYNAMICS=true
PAPER_PEAK_LOG_STEP_PCT=1
PAPER_STATS_INTERVAL_MS=300000

# ============================================================
# W6.4 — paper-trader observability (dashboard / advisor / report)
# ============================================================
# Папка с *.jsonl всех paper-стратегий. Dashboard, advisor, healthcheck, hourly-report — все читают её.
PAPER2_DIR=/opt/solana-alpha/data/paper2

# ------------------------------------------------------------
# Dashboard HTTP Basic Auth (W7.1.1 — restored)
# ------------------------------------------------------------
# Если оба значения непустые — dashboard-organizer-paper включает Basic Auth
# на ВСЕХ маршрутах кроме /api/health (используется внешним uptime-чеком).
# Если хотя бы одно пустое — auth отключён (legacy-поведение).
DASHBOARD_BASIC_USER=
DASHBOARD_BASIC_PASSWORD=
DASHBOARD_BASIC_REALM=Solana Alpha Dashboard

# Telegram. ОБЯЗАТЕЛЬНО для hourly-report, advisor, healthcheck.
# Единственный источник для всех скриптов — /opt/solana-alpha/.env (грузится через `import 'dotenv/config'`).
# НЕ дублировать в .env.hourly или других файлах — legacy .env.hourly игнорируется.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram cooldown / quiet (опционально, см. scripts/lib/telegram.mjs)
TELEGRAM_QUIET_FROM=
TELEGRAM_QUIET_TO=
TELEGRAM_COOLDOWN_HEALTH_PLATFORM_MS=600000
TELEGRAM_COOLDOWN_REPORT_STRATEGIES_MS=
TELEGRAM_COOLDOWN_ADVICE_PAPER2_MS=
TELEGRAM_COOLDOWN_ADVICE_DIGEST_MS=
TELEGRAM_COOLDOWN_PATH=/opt/solana-alpha/data/telegram-cooldown.json

# paper2-healthcheck
PAPER2_MAX_STALE_MIN=20
PAPER2_HEALTH_TELEGRAM_ON_ALERT=1
PAPER2_HEALTH_TELEGRAM_ON_OK=0

# paper2-advisor
PAPER2_ADVISOR_MIN_TRADES=12
PAPER2_ADVISOR_OUT=/opt/solana-alpha/data/paper2/advisor-latest.json

# advisor-digest
