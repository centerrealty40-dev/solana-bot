# === solana-alpha v2 (post-W2 slim) ===

# --- Database ---
# Preferred new name (matches ops docs). Legacy alias: DATABASE_URL (still supported in code).
SA_PG_DSN=postgresql://salpha:CHANGE_ME@localhost:5432/solana_alpha

# --- Redis (required by src/core/config.ts when any code imports DB/logger chain) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Solana RPC (paid endpoint, used by scam-farm-detective и future sa-stream) ---
SA_RPC_URL=https://api.mainnet-beta.solana.com
SA_RPC_FALLBACK_URLS=

# --- Telegram alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Dashboard ---
HOST=0.0.0.0
PORT=3008
STORE_PATH=/opt/solana-alpha/data/paper2/organizer-paper.jsonl

# --- Cloudflare R2 (daily atlas backup) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# --- Scam-farm detective (reference run, off by default) ---
SCAM_FARM_LOOKBACK_DAYS=14
SCAM_FARM_WRITE_ATLAS=0
