PAPER_MIG_MIN_VOL_5M_USD=1800
PAPER_MIG_MIN_BUYS_5M=18
PAPER_MIG_MIN_SELLS_5M=8
PAPER_MIG_MIN_AGE_MIN=2
PAPER_MIG_MAX_AGE_MIN=25
