# === solana-alpha v2 (post-W2 slim) ===

# --- Database ---
# Preferred new name (matches ops docs). Legacy alias: DATABASE_URL (still supported in code).
SA_PG_DSN=postgresql://salpha:CHANGE_ME@localhost:5432/solana_alpha

# --- Redis (required by src/core/config.ts when any code imports DB/logger chain) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Solana RPC (paid endpoint, used by scam-farm-detective и future sa-stream) ---
SA_RPC_URL=https://api.mainnet-beta.solana.com
SA_RPC_FALLBACK_URLS=

# --- Telegram alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Dashboard ---
HOST=0.0.0.0
PORT=3008
STORE_PATH=/opt/solana-alpha/data/paper2/organizer-paper.jsonl

# --- Cloudflare R2 (daily atlas backup) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# --- Scam-farm detective (reference run, off by default) ---
SCAM_FARM_LOOKBACK_DAYS=14
SCAM_FARM_WRITE_ATLAS=0

# --- Streaming ingest (sa-stream) ---
# HTTPS JSON-RPC base (QuickNode example). Falls back to QUICKNODE_HTTP_URL then HELIUS_RPC_URL if unset.
SA_RPC_HTTP_URL=
# Optional explicit WSS; if empty, derived from SA_RPC_HTTP_URL (https→wss).
SA_RPC_WS_URL=
SA_STREAM_PROGRAM_IDS=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
SA_STREAM_COMMITMENT=confirmed
SA_STREAM_BATCH_SIZE=50
SA_STREAM_BATCH_MS=1000
SA_STREAM_RECONNECT_MIN_MS=1000
SA_STREAM_RECONNECT_MAX_MS=30000
SA_STREAM_LOG_EVERY_N=500

# --- Parser (sa-parser) ---
SA_PARSER_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
SA_PARSER_BATCH_SIZE=25
SA_PARSER_TICK_MS=1500
SA_PARSER_RPC_BATCH=5
SA_PARSER_RPC_TIMEOUT_MS=8000
SA_PARSER_LOOKBACK_HOURS=6
SA_PARSER_MAX_INFLIGHT=2
SA_PARSER_LOG_EVERY_N=200
SA_PARSER_DRY_RUN=false
# TODO(W4.1): replace with live SOL/USD feed.
SA_SOL_USD_FALLBACK=150.0

# --- Atlas writes (sa-atlas) ---
SA_ATLAS_BATCH_SIZE=200
SA_ATLAS_TICK_MS=1500
SA_ATLAS_LOOKBACK_HOURS=12
SA_ATLAS_LOG_EVERY_N=1000
SA_ATLAS_TAG_WINDOW_HOURS=24
SA_ATLAS_FLOWS_ENABLED=true
SA_ATLAS_TAGS_ENABLED=true
SA_ATLAS_DRY_RUN=false

# ===== W6.1 — DEX collectors =====
# All collectors use sane defaults; override only if needed.

# Raydium / Meteora / Orca / Moonshot collectors (DexScreener + GeckoTerminal):
RAYDIUM_COLLECTOR_INTERVAL_MS=60000
METEORA_COLLECTOR_INTERVAL_MS=60000
ORCA_COLLECTOR_INTERVAL_MS=60000
MOONSHOT_COLLECTOR_INTERVAL_MS=60000

# Jupiter route watcher:
JUPITER_WATCHER_INTERVAL_MS=60000
JUPITER_WATCHER_LOOKBACK_HOURS=2
JUPITER_WATCHER_MAX_MINTS=20
JUPITER_WATCHER_QUOTE_IN_USD=25
JUPITER_WATCHER_SLIPPAGE_BPS=300
# CRITICAL: must be '0' until W6.7 (rpc_tasks table not created yet).
JUPITER_WATCHER_ENQUEUE_RPC=0

# Direct-LP detector:
DIRECT_LP_DETECTOR_INTERVAL_MS=60000
DIRECT_LP_FRESH_LOOKBACK_MINUTES=10
DIRECT_LP_HISTORY_LOOKBACK_HOURS=168
DIRECT_LP_MIN_LIQUIDITY_USD=0
# CRITICAL: must be '0' until W6.7 (rpc_tasks table not created yet).
DIRECT_LP_ENQUEUE_RPC=0

# ============================================================
# W6.3a — paper-trader skeleton
