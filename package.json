{
  "name": "solana-alpha-research-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Modular research platform for testing on-chain alpha hypotheses on Solana DEX",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:hygiene": "node scripts/check-release-hygiene.mjs",
    "check:hygiene:integration": "node scripts/check-release-hygiene.mjs --git-clean",
    "verify": "npm run typecheck && npm run check:hygiene && npm run test",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "dashboard": "tsx scripts-tmp/dashboard-server.ts",
    "stream": "tsx src/scripts/stream.ts",
    "parser": "tsx src/scripts/parser.ts",
    "atlas": "tsx src/scripts/atlas.ts",
    "papertrader": "tsx src/scripts/papertrader.ts",
    "live-oscar": "tsx src/scripts/live-oscar.ts",
    "live-slippage-report": "tsx src/scripts/live-slippage-report.ts",
    "paper2:dashboard": "tsx scripts-tmp/dashboard-server.ts",
    "paper2:advisor": "node scripts-tmp/paper2-advisor.mjs",
    "paper2:diagnose-holders-gpa": "node scripts-tmp/paper2-diagnose-holders-gpa.mjs",
    "paper2:diagnose-dip-recovery": "tsx scripts-tmp/paper2-diagnose-dip-recovery.ts",
    "paper2:healthcheck": "node scripts-tmp/paper2-healthcheck.mjs",
    "paper2:hourly-report": "node scripts-tmp/hourly-telegram-report.mjs",
    "paper2:advisor-digest": "node scripts-tmp/advisor-digest.mjs",
    "paper2:post-mortem": "node scripts-tmp/post-mortem-paper-v1.mjs",
    "collector:http-budget": "node scripts-tmp/collector-http-budget.mjs",
    "collector:log-watch": "node scripts-tmp/collector-log-watch.mjs",
    "collector:profile-once": "node scripts-tmp/collector-profile-once.mjs",
    "sa-grws-collector": "node scripts-tmp/sa-grws-collector.mjs",
    "sa-grws-analytics": "node scripts-tmp/sa-grws-analytics.mjs",
    "sa-grws-pilot-diagnose": "node scripts-tmp/sa-grws-pilot-diagnose.mjs",
    "sa-wallet-orchestrator": "node scripts-tmp/sa-wallet-orchestrator.mjs",
    "sa-qn-global-report": "node scripts-tmp/sa-qn-global-report.mjs",
    "sa-qn-budget-check": "node scripts-tmp/sa-qn-budget-check.mjs",
    "wallet-backfill:run": "tsx src/scripts/wallet-backfill-run.ts",
    "wallet-backfill:pilot": "tsx src/scripts/wallet-backfill-pilot.ts",
    "wallet-funding:backfill": "tsx src/scripts/wallet-funding-backfill.ts",
    "diag:live-wallet-rpc": "tsx scripts/diag-live-wallet-rpc.ts",
    "qn:smoke": "tsx src/scripts/qn-smoke.ts",
    "paper2:backtest": "tsx src/scripts/paper2-strategy-backtest.ts",
    "paper2:timeout-slice": "tsx src/scripts/paper2-timeout-slice.ts",
    "scam-farm:detect": "tsx src/scripts/scam-farm-detective.ts",
    "wallet-intel:doctor": "tsx src/scripts/wallet-intel-doctor.ts",
    "wallet-intel:policy": "tsx src/scripts/wallet-intel-policy.ts",
    "wallet-intel:mint-check": "tsx src/scripts/wallet-intel-mint-check.ts",
    "wallet-intel:pipeline": "tsx src/scripts/wallet-intel-pipeline.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@solana/web3.js": "^1.95.0",
    "bs58": "^4.0.1",
    "bullmq": "^5.30.0",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "p-limit": "^6.1.0",
    "p-queue": "^8.0.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.4",
    "tsx": "^4.19.2",
    "undici": "^7.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bs58": "^4.0.4",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
