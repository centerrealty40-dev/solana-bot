{
  "name": "solana-alpha-research-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Modular research platform for testing on-chain alpha hypotheses on Solana DEX",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:collector:dexscreener": "tsx watch src/collectors/dexscreener-cli.ts",
    "dev:scoring": "tsx watch src/scoring/cli.ts",
    "dev:runner": "tsx watch src/runner/cli.ts",
    "backfill:wallets": "tsx src/scripts/backfill-wallets.ts",
    "scores:compute": "tsx src/scripts/compute-scores.ts",
    "hypothesis:list": "tsx src/scripts/list-hypotheses.ts",
    "hypothesis:run": "tsx src/scripts/run-hypothesis.ts",
    "hypothesis:evaluate": "tsx src/scripts/evaluate-hypothesis.ts",
    "views:install": "tsx src/scripts/install-views.ts",
    "telegram:test": "tsx src/scripts/telegram-test.ts",
    "report:daily": "tsx src/scripts/daily-report.ts",
    "helius:wipe": "tsx src/scripts/helius-wipe.ts",
    "helius:status": "tsx src/scripts/helius-status.ts",
    "watchlist:seed": "tsx src/scripts/seed-watchlist.ts",
    "watchlist:seed:helius": "tsx src/scripts/seed-watchlist-helius.ts",
    "watchlist:seed:pump": "tsx src/scripts/seed-watchlist-pump.ts",
    "watchlist:seed:longform": "tsx src/scripts/seed-watchlist-longform.ts",
    "watchlist:seed:rotation": "tsx src/scripts/seed-watchlist-rotation.ts",
    "watchlist:deepdive": "tsx src/scripts/wallet-deep-dive.ts",
    "whales:extract": "tsx src/scripts/extract-whales.ts",
    "watchlist:show": "tsx src/scripts/watchlist-show.ts",
    "watchlist:add": "tsx src/scripts/watchlist-add.ts",
    "watchlist:remove": "tsx src/scripts/watchlist-remove.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "ws": "^8.18.0",
    "undici": "^7.0.0",
    "pg": "^8.13.0",
    "postgres": "^3.4.4",
    "bullmq": "^5.30.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "decimal.js": "^10.4.3",
    "p-limit": "^6.1.0",
    "p-queue": "^8.0.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "@types/pg": "^8.11.10",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.4",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.14.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "prettier": "^3.3.3"
  }
}
