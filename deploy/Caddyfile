# Replace YOUR_DOMAIN with your actual subdomain (e.g. solana-bot.example.com).
# Caddy will automatically obtain a Let's Encrypt cert on first request.

YOUR_DOMAIN {
    encode gzip

    # Helius webhook receiver — public POST endpoint
    handle /webhooks/* {
        reverse_proxy localhost:3000
    }

    # Read-only dashboard API. Optionally protect with basic auth or restrict by IP.
    handle /api/* {
        reverse_proxy localhost:3000
        # Uncomment to add basic auth:
        # basicauth {
        #     admin JDJhJDEwJC4uLg==   # generate with: caddy hash-password
        # }
    }

    # Health check, no auth.
    handle /health {
        reverse_proxy localhost:3000
    }

    # Everything else — 404
    handle {
        respond "not found" 404
    }

    log {
        output file /var/log/caddy/solana-alpha.log {
            roll_size 50mb
            roll_keep 5
        }
    }
}
